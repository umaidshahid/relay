# Relay LLM Proxy — Operator Configuration Example
# Copy this file to config.yml and edit as needed.
# config.yml is NOT committed to git (see .gitignore).
#
# Per-user backend credentials (provider API keys) are stored securely in the
# database. This file contains ONLY operator-level settings.
#
# Required environment variables (set in .env — never commit .env):
#   RELAY_ENCRYPT_KEY  — Fernet key for encrypting provider credentials
#                        Generate once: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   JWT_SECRET         — Secret for signing JWT sessions (any random string ≥32 chars)
#
# Per-model cost rates in USD per token.
# If a model is not listed, cost is recorded as 0.0.
# Use the exact model name as sent to (or reported by) the backend.
cost_rates:
  gpt-4o:
    input_per_token: 0.0000025
    output_per_token: 0.000010
  gpt-4o-mini:
    input_per_token: 0.00000015
    output_per_token: 0.00000060
  llama3:
    input_per_token: 0.0
    output_per_token: 0.0
  llama3.1:
    input_per_token: 0.0
    output_per_token: 0.0
