# Caddyfile for Relay
# Caddy handles HTTPS automatically via Let's Encrypt.
# Caddy sets X-Forwarded-Proto/Host by default; uvicorn must run with
# --proxy-headers (see Dockerfile) so request-derived OAuth callback URLs
# come out as https://relay.umaid.dev/... rather than http://proxy:8000/...

relay.umaid.dev {
    reverse_proxy proxy:8000
}

# Local development without TLS (comment out the block above and use this):
# :8080 {
#     reverse_proxy proxy:8000
# }
